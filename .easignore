# Keep EAS uploads focused on the Expo app inside apps/native,
# but include root package.json and config for EAS build to work.
*

# Include the native Expo app
!apps/
!apps/native/
!apps/native/**

# Include root package.json (needed for npm install during EAS build)
!package.json

# Include Expo/EAS config files at root
!app.json
!eas.json
!.easignore
!.gitignore
